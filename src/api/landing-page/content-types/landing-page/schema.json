    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "landing.feature-card"
    },
    "integrationsHeading": {
      "type": "string"
    },
    "integrationsDescription": {
      "type": "text"
    },
    "integrations": {
      "type": "component",
      "repeatable": true,
      "component": "landing.integration-item"
    },
    "showcaseHeading": {
      "type": "string"
    },
    "showcaseDescription": {
      "type": "text"
    },
    "showcaseItems": {
      "type": "component",
      "repeatable": true,
      "component": "landing.showcase-item"
    },
    "joinTeam": {
      "type": "component",
      "repeatable": false,
      "component": "landing.join-team"
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    },
    "socialImage": {
      "type": "media",
      "multiple": false,
